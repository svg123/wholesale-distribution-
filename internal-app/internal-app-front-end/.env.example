# Central Command Frontend Configuration
VITE_API_URL=http://localhost:5001
VITE_API_TIMEOUT=30000
VITE_APP_NAME=Central Command - Pharma Wholesale
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_MOCK_API=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# JWT Token
VITE_TOKEN_STORAGE_KEY=cc_auth_token
VITE_USER_STORAGE_KEY=cc_auth_user
